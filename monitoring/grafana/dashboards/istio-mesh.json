          "expr": "sum by (destination_service_name) (rate(istio_requests_total{reporter=\"destination\",destination_service_name!~\"unknown|\",cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{destination_service_name}}",
          "refId": "A"
