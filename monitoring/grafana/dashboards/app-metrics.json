      "targets": [
        {
          "expr": "sum by (cluster) (rate(mcplatform_http_requests_total{service=\"order-service\",route=\"/orders\",cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{cluster}}",
          "refId": "A"
        }
      ]
    },
