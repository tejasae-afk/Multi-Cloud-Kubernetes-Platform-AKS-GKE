      "id": 4,
      "type": "timeseries",
      "title": "order throughput",
      "description": "I look at the write path here because it is the first thing that gets weird when inventory goes away.",
      "datasource": {
        "type": "prometheus",
        "uid": "thanos"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
